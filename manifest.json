{
  "manifest_version": 3,
  "name": "Keeply",
  "version": "1.0.0",
  "description": "Save, organize, and restore all your Chrome tabs with a single click — group and name tabs for easy access anytime.",
  "permissions": ["tabs", "storage", "tabGroups"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon.png",
      "48": "assets/icon.png",
      "128": "assets/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  }
}
